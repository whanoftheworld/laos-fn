# LAOS-Finance environment template
# Copy to .env and fill in real values; never commit .env

# === Backend (Fastify) ===
PORT=8080
NODE_ENV=development

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB=laos_finance

# Redis (optional, for cache/pub-sub)
REDIS_URL=redis://localhost:6379

# Auth secrets (admin)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALG=RS256
SESSION_SECRET=

# Notification webhooks
LINE_NOTIFY_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stream sources (HLS)
STREAM_PRIMARY_URL=
STREAM_FALLBACK_URL=

# Analytics
GA4_MEASUREMENT_ID=
PLAUSIBLE_DOMAIN=

# === Frontend (Vite) — must prefix with VITE_ to be exposed ===
VITE_API_URL=http://localhost:8080
VITE_SOCKET_URL=http://localhost:8080
